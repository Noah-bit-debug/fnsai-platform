# Clerk Auth
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (Azure PostgreSQL)
DATABASE_URL=postgresql://sentrixai_user:PASSWORD@sentrixai.postgres.database.azure.com:5432/sentrixai?sslmode=require

# Microsoft Graph API (Azure AD App Registration)
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3001/auth/microsoft/callback

# (Foxit eSign removed — replaced by the built-in eSign module at /esign.)

# ClerkChat SMS
CLERKCHAT_API_KEY=your-clerkchat-api-key
CLERKCHAT_BASE_URL=https://api.clerkchat.com/v1
CLERKCHAT_FROM_NUMBER=+15550000000

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Azure (production)
AZURE_STORAGE_CONNECTION_STRING=
